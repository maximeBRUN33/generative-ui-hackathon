      { "authorName": "Aisha Khan",  "authorInitials": "AK", "projectLabel": "Lyra",  "timeLabel": "3 hours ago", "kind": "mention",       "summary": "Mentioned you on Suggestion ranker v2: 'Need a call on ranking weights.'" }
