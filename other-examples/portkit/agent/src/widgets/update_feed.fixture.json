      "authorInitials": { "path": "authorInitials" },
      "projectLabel": { "path": "projectLabel" },
      "timeLabel": { "path": "timeLabel" },
      "kind": { "path": "kind" },
      "summary": { "path": "summary" }
    }
  ],
  "data": {
