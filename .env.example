AGENT_URL=http://localhost:8123

# Per-agent endpoints served by agent/main.py (FastAPI on :8123).
FIXED_AGENT_URL=http://localhost:8123/fixed
DYNAMIC_AGENT_URL=http://localhost:8123/dynamic
LEGAL_AGENT_URL=http://localhost:8123/legal

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LLM PROVIDER — Default is Google Gemini via OpenAI-compatibility.
# Get a free-tier key: https://aistudio.google.com/apikey
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Default: Gemini 3.5 Flash via the native Google Gen AI SDK (langchain-google-genai).
# Released 2026-05-19, current Google flagship Flash. See FROZEN.md.
GEMINI_API_KEY=

# Optional model override (default matches agent/main.py):
# MODEL=gemini-3.5-flash

# ─── To swap to OpenAI (GPT-5.5, released 2026-04-23) ─────────
# Uncomment the lines below, comment out GEMINI_API_KEY, and in agent/main.py
# remove the base_url= line (or set MODEL_BASE_URL= empty to clear it).
# OPENAI_API_KEY=
# MODEL=gpt-5.5-mini          # or gpt-5.5 for the larger Pro tier

# ─── To swap to Anthropic Claude (Opus 4.7, released 2026-04-16) ──
# In agent/main.py, replace the ChatOpenAI(...) block with:
#   from langchain_anthropic import ChatAnthropic
#   model = ChatAnthropic(model="claude-opus-4-7", api_key=os.getenv("ANTHROPIC_API_KEY"))
# Opus 4.7 is the current top-tier (1M context, x-high reasoning). For a balanced
# choice prefer claude-sonnet-4-6 (faster, cheaper, still 4.x-generation).
# ANTHROPIC_API_KEY=

# ─── To swap to any LiteLLM-compatible provider ───────────────
# Set MODEL_BASE_URL to your LiteLLM proxy URL and GEMINI_API_KEY to the proxy auth.
# Works with Bedrock, Vertex, Ollama, LM Studio, etc.
# MODEL_BASE_URL=https://your-litellm-proxy/v1/
# MODEL=your-litellm-model-id

# ─── Offline mode ─────────────────────────────────────────────
# Set OFFLINE=1 to make the /fixed endpoint serve a built-in sample dashboard
# (a canned Tesla Q3 FY24 A2UI surface) with NO Gemini call and no API key —
# handy for a venue-Wi-Fi fallback or a key-less first look. Only /fixed works
# offline; /dynamic and /legal still require GEMINI_API_KEY. `pnpm smoke`
# exercises this path (offline /fixed probe).
# OFFLINE=

# ─── Project ops dataset path ─────────────────────────────────
# Path to the project-ops JSON seed (read by agent/src/query.py).
# Default: ./data/projectops.json. Override to point at any JSON file
# with the same 6-entity shape (people/projects/sprints/tasks/risks/updates).
DATA_PATH=./data/projectops.json
